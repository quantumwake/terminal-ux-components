{
  "name": "@quantumwake/terminal-ux-components",
  "version": "0.3.4",
  "description": "Terminal-style React UX components for the Alethic ISM apps.",
  "license": "MIT",
  "author": "QuantumWake",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quantumwake/terminal-ux-components.git"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "terminal",
    "design-system",
    "alethic"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run build",
    "release": "npm run lint && npm run build && npm publish --access public",
    "release:dry": "npm run lint && npm run build && npm publish --access public --dry-run",
    "version:patch": "npm version patch && npm run release",
    "version:minor": "npm version minor && npm run release"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "lucide-react": ">=0.4.0",
    "@headlessui/react": ">=2.0.0",
    "@heroicons/react": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    },
    "@headlessui/react": {
      "optional": true
    },
    "@heroicons/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.563.0",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
